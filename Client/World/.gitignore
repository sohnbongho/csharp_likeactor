# ==============================================================
# Unity 프로젝트 .gitignore (Client/World 한정)
# 이 파일은 Client/World/ 디렉토리 기준으로만 적용된다.
# 루트의 Library/ (C# Class Library) 와는 충돌하지 않는다.
# ==============================================================

# Unity가 자동 생성하는 캐시/임시 폴더 (가장 무거움)
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# 에셋 임포트/플레이어 캐시
Assets/AssetStoreTools*
Assets/Plugins/Editor/JetBrains*

# Unity가 자동 생성하는 IDE 솔루션 (사용자가 직접 만든 게 아님)
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity 플랫폼 빌드 산출물
*.apk
*.aab
*.unitypackage
*.app
ExportedObj/
.consulo/

# Unity 메타 부산물
*.csproj.DotSettings
*.pidb.meta
*.pdb.meta
*.mdb.meta
*.FbxPrefab

# Crashlytics
crashlytics-build.properties

# IDE
.vs/
.idea/
.gradle/

# OS
.DS_Store
Thumbs.db
